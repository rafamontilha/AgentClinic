# Anthropic API — required for the visit triage + prescription pipeline
ANTHROPIC_API_KEY=

# Claude model to use for triage and prescription (defaults to claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# API key that agent clients must send as: Authorization: Bearer <key>
# If unset, API auth is disabled with a startup warning (dev mode only)
AGENTCLINIC_API_KEY=

# SQLite database file path (relative to project root)
DATABASE_PATH=data/agentclinic.db

# Staff dashboard session secret — 32+ character random string
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# Single shared staff password for the dashboard login
STAFF_PASSWORD=

# Visit follow-up window in hours before a visit expires to EXPIRED
FOLLOWUP_WINDOW_HOURS=72

# Background job interval in minutes
EXPIRE_CHECK_INTERVAL_MINUTES=15

# Per-patient visit rate limit (visits per hour)
RATE_LIMIT_VISITS_PER_HOUR=10
